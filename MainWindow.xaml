<Window
    x:Class="WinToolbarMediaButtons.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>

    <Grid x:Name="RootGrid" Background="#1c1c1c" RightTapped="OnRightTapped" RequestedTheme="Dark"
          PointerPressed="RootGrid_PointerPressed"
          PointerMoved="RootGrid_PointerMoved"
          PointerReleased="RootGrid_PointerReleased">
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="ButtonBackground"                   Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBorderBrush"                  Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"        Color="#22FFFFFF"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"       Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"            Color="#11FFFFFF"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed"           Color="Transparent"/>
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>
            </ResourceDictionary>
        </Grid.Resources>

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Spacing="2"
                    Padding="4,0,0,0">
            <Button Width="52" Height="52" Padding="0" Click="BtnPrev_Click"
                    ToolTipService.ToolTip="Previous track">
                <FontIcon Glyph="&#xE892;" FontFamily="Segoe Fluent Icons" FontSize="22"/>
            </Button>
            <Button Width="52" Height="52" Padding="0" Click="BtnPlayPause_Click"
                    ToolTipService.ToolTip="Play / Pause">
                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontFamily="Segoe Fluent Icons" FontSize="22"/>
            </Button>
            <Button Width="52" Height="52" Padding="0" Click="BtnNext_Click"
                    ToolTipService.ToolTip="Next track">
                <FontIcon Glyph="&#xE893;" FontFamily="Segoe Fluent Icons" FontSize="22"/>
            </Button>
            <Border Width="1" Background="{ThemeResource SystemBaseMediumColor}" Margin="10,10"/>
            <Button Width="52" Height="52" Padding="0" Click="BtnMute_Click"
                    ToolTipService.ToolTip="Mute">
                <FontIcon x:Name="MuteIcon" Glyph="&#xE74F;" FontFamily="Segoe Fluent Icons" FontSize="22"/>
            </Button>

            <!-- Кнопка громкости -->
            <Border x:Name="BtnVolumeControl" Width="156" Height="52"
                    CornerRadius="4" Background="#15FFFFFF"
                    ToolTipService.ToolTip="Drag to change volume"
                    PointerEntered="BtnVolumeControl_PointerEntered"
                    PointerExited="BtnVolumeControl_PointerExited">
                <Grid>
                    <Rectangle x:Name="VolumeFillBar"
                               HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Width="0" Fill="#1EFFFFFF"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="8">
                        <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;"
                                  FontFamily="Segoe Fluent Icons" FontSize="18"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="VolumePercentText"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </Grid>
</Window>
